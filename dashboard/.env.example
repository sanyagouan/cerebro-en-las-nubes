# ============================================
# DASHBOARD FRONTEND - Variables de Entorno
# ============================================
# Copia este archivo a .env.local para desarrollo local
# O configura estas variables en Coolify para producción

# URL del Backend (FastAPI)
# Desarrollo: Se usa el proxy de Vite (ver vite.config.ts)
# Producción: URL completa del backend desplegado
VITE_API_URL=

# URL del WebSocket (opcional, se deriva de VITE_API_URL)
# Si no se especifica, se construye automáticamente cambiando http:// por ws://
VITE_WS_URL=

# ============================================
# EJEMPLOS DE CONFIGURACIÓN
# ============================================

# Desarrollo local (proxy Vite activo)
# VITE_API_URL=
# (dejar vacío para usar el proxy configurado en vite.config.ts)

# Producción Coolify
# VITE_API_URL=https://go84sgscs4ckcs08wog84o0o.app.generaia.site

# Desarrollo con backend remoto
# VITE_API_URL=https://mi-backend.example.com
